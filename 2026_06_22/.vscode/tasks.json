{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build sorting (debug)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "mkdir -p ${workspaceFolder}/build && clang++ -g -O0 -std=c++11 -o ${workspaceFolder}/build/sorting ${workspaceFolder}/sorting.cpp ${workspaceFolder}/linked_list.cpp"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "build sorting (release)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "mkdir -p ${workspaceFolder}/build && clang++ -O2 -std=c++11 -o ${workspaceFolder}/build/sorting ${workspaceFolder}/sorting.cpp ${workspaceFolder}/linked_list.cpp"
            ],
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
